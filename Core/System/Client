    public void Connect()
    {
        client = new TcpClinet();
        client.Connect(host, port);
        NetworkStream stream = client.GetStream();
        reader = new StreamReader(stream, Endcoding.UTF8, leaveOpen: true);
        writer = new StreamWriter(stream, Encoding.UTF8, leaveOpen: true)
        {
            AutoFlush = true
        };
        isRunning = true;
        receiveThread = new Thread(ReceiveLoop)
        {
            IsBackground = true,
            Name = "Fayte Client Receive Thread"
        };
        receiveThread.Start();
        Console.WriteLine("Connected");
    }
    public void Disconnect()
    {
        isRunning = false;
        reader?.Dispose();
        writer?.Dispose();
        client?.Dispose();
        reader = null;
        writer = null;
        client = null;
        Console.WriteLine("Disconnected.");
    }
